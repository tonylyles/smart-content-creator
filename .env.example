# ==================== 环境配置模板 ====================
# 复制本文件为 .env 并填入真实值

# ==================== LLM API 配置 ====================
# DeepSeek API（主要）
LLM_API_KEY=sk-your-api-key-here
OPENAI_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# ==================== 向量数据库配置 ====================
VECTOR_DB_URL=http://localhost:6333

# ==================== 微信公众号配置 ====================
WECHAT_ACCOUNT_ID=gh_xxxxxxxxxxxx
WECHAT_APP_ID=wx_xxxxxxxxxxxx
WECHAT_PASSWORD=your-password-here

# ==================== 调度系统配置 ====================
# SLA 目标时间（秒），默认 1800（30分钟）
SCHEDULER_SLA_SECONDS=1800
# 任务重试次数，默认 3
SCHEDULER_MAX_RETRIES=3
# JobStore 数据库路径
SCHEDULER_DB_PATH=data/scheduler_jobs.sqlite

# ==================== 爬虫配置 ====================
# 爬虫请求超时（秒）
CRAWLER_TIMEOUT=10
# 爬虫请求间隔（秒），避免被封
CRAWLER_DELAY=2
# User-Agent
CRAWLER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=logs/
